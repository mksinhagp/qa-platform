# Application Environment
NODE_ENV=development

# Dashboard Web (Next.js)
NEXT_PUBLIC_APP_URL=http://localhost:3000
DASHBOARD_PORT=3000
DASHBOARD_SESSION_SECRET=your-session-secret-min-32-chars-change-in-production

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=qa_platform
POSTGRES_USER=qa_user
POSTGRES_PASSWORD=change-this-password-in-production
POSTGRES_SSL_MODE=disable

# Vault (Argon2id + AES-256-GCM)
VAULT_BOOTSTRAP_REQUIRED=true
VAULT_MASTER_PASSWORD_MIN_LENGTH=12
VAULT_UNLOCK_TTL_SECONDS=1800
VAULT_UNLOCK_IDLE_RESET_SECONDS=300
VAULT_ARGON2ID_MEMORY=131072
VAULT_ARGON2ID_ITERATIONS=3
VAULT_ARGON2ID_PARALLELISM=2
VAULT_ARGON2ID_SALT_LENGTH=16

# Runner Service
RUNNER_HOST=runner
RUNNER_PORT=4000
RUNNER_API_BASE_URL=http://runner:4000
RUNNER_CONCURRENCY_CAP=4

# Artifacts
ARTIFACT_ROOT_PATH=/artifacts
ARTIFACT_RETENTION_TRACE_DAYS=30
ARTIFACT_RETENTION_VIDEO_DAYS=30
ARTIFACT_RETENTION_SCREENSHOT_DAYS=90
ARTIFACT_RETENTION_HAR_DAYS=30
ARTIFACT_RETENTION_LOG_DAYS=90
ARTIFACT_RETENTION_MP4_DAYS=180
ARTIFACT_RETENTION_RECORD_DAYS=365

# Ollama (Local LLM)
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_FAST_MODEL=llama3.1:8b
OLLAMA_RICH_MODEL=qwen2.5:14b

# Email Integration
EMAIL_ENABLED=false
EMAIL_DEFAULT_IMAP_HOST=imap.example.com
EMAIL_DEFAULT_IMAP_PORT=993
EMAIL_DEFAULT_IMAP_SECURE=true

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Feature Flags
FEATURE_ACCESSIBILITY=true
FEATURE_PERSONA_ENGINE=true
FEATURE_MATRIX_RUNS=true
FEATURE_APPROVALS=true

# Auth (Custom)
AUTH_SESSION_IDLE_TIMEOUT_SECONDS=28800
AUTH_SESSION_ABSOLUTE_TIMEOUT_SECONDS=2592000
AUTH_PASSWORD_MIN_LENGTH=8
AUTH_PASSWORD_REQUIRE_SPECIAL=true
AUTH_PASSWORD_REQUIRE_NUMBER=true

# Business Rules
BUSINESS_RULES_PATH=./sites

# Docker Compose Override (for local dev)
COMPOSE_PROFILES=default

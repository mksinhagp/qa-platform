{
  "name": "@qa-platform/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./migrations": {
      "import": "./dist/migrations-index.js",
      "types": "./dist/migrations-index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "tsx src/test.ts",
    "migrate": "tsx src/migrations.ts"
  },
  "dependencies": {
    "pg": "^8.11.3",
    "@types/pg": "^8.10.9",
    "@qa-platform/shared-types": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
